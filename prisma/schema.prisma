generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Notice {
  id          Int      @id @default(autoincrement())
  title       String
  body        String   @db.Text
  category    Category
  priority    Priority
  publishDate DateTime
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Category {
  EXAM
  EVENT
  GENERAL
}

enum Priority {
  NORMAL
  URGENT
}